PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.example.mongodb.net/orderbridge?retryWrites=true&w=majority
# MONGODB_URL and MONGO_URL are also supported for compatibility.

# Optional: use this when mongodb+srv Atlas DNS lookup fails locally.
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
DEBUG_DB_ERRORS=false

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

HERMES_API_BASE_URL=
HERMES_API_URL=
HERMES_AGENT_URL=
HERMES_API_KEY=
HERMES_TIMEOUT_MS=45000
HERMES_AGENT_MODEL=hermes-agent
MCP_SHARED_SECRET=

WASENDER_API_URL=https://www.wasenderapi.com
WASENDER_API_KEY=
WASENDER_WEBHOOK_SECRET=
APP_PUBLIC_URL=
